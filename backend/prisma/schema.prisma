generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}


model User {
  id         Int      @id @default(autoincrement())
  name       String
  lastname   String
  username   String   @unique
  password   String
  hash       String?  
  role       String @default("user")
  created_at DateTime @default(now())
    tasks Task[]

    logs Logs[]
}

model Task {
  id Int @id @default(autoincrement())
  name String
  description String
  priority Boolean
  user_id Int
  user User @relation(fields: [user_id], references: [id])
}

model Logs{
  id Int @id @default(autoincrement())
  statusCode Int
  timeStamp DateTime
  path String @db.Text
  error String @db.Text
  errorcode String @db.Text
  session_id Int?
  
  user User? @relation(fields: [session_id], references: [id])
}